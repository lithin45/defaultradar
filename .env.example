# ----------------------------------------------------------------------------
# DefaultRadar environment configuration
# Copy to `.env` (the Makefile / docker compose read it) and adjust as needed.
# Every value has a sane default in src/defaultradar/config.py, so an empty
# .env still works for local runs.
# ----------------------------------------------------------------------------

# --- MLflow ---
# Host-side clients (make train / make eval) talk to the server here.
MLFLOW_TRACKING_URI=http://localhost:5000
# Inside the docker network, services reach MLflow at http://mlflow:5000
# (compose injects that automatically; this var is for host tools).
MLFLOW_REGISTERED_MODEL_NAME=defaultradar-default-classifier
MLFLOW_EXPERIMENT_NAME=defaultradar

# --- Postgres (MLflow backend store) ---
# POSTGRES_PORT is only a host *debug* mapping; MLflow reaches Postgres
# internally at postgres:5432. If you already run Postgres locally on 5432,
# set this to e.g. 5433 to avoid a "port is already allocated" error.
POSTGRES_USER=mlflow
POSTGRES_PASSWORD=mlflow
POSTGRES_DB=mlflow
POSTGRES_PORT=5432

# --- Service ports (host) ---
MLFLOW_PORT=5000
SCORER_PORT=8000
PREFECT_PORT=4200

# --- Prefect ---
PREFECT_API_URL=http://localhost:4200/api

# --- Determinism ---
DEFAULTRADAR_SEED=42

# --- Promotion / quality gate thresholds ---
# ROC-AUC floor 0.67: the honest achievable level for this leakage-safe,
# application-time, time-split dataset (model achieves ~0.684). See README.
DEFAULTRADAR_ROC_AUC_MIN=0.67
DEFAULTRADAR_PSI_THRESHOLD=0.20
DEFAULTRADAR_LATENCY_P95_MS=300
