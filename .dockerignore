# Build context hygiene — keep images small and builds fast.
.git/
.github/
.venv/
venv/
__pycache__/
*.py[cod]
.pytest_cache/
.ruff_cache/
.coverage
htmlcov/

# Large local state — never copy into images
data/
mlruns/
mlartifacts/
reports/
.prefect/
prefect.db

# Local env / editor
.env
.env.local
.DS_Store
.idea/
.vscode/
